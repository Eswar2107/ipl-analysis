{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "ipldatafactory2107"
		},
		"iplstorage_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'iplstorage'"
		},
		"ipldatabricks_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0405-090644-rhaojo2j"
		},
		"iplstorage_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://ipl2019.dfs.core.windows.net/"
		},
		"iplvault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://ipl2109key.vault.azure.net/"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "ipldatafactory2107_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"iplstorage_accountKey": {
						"value": "[parameters('iplstorage_accountKey')]"
					},
					"iplstorage_properties_typeProperties_url": {
						"value": "[parameters('iplstorage_properties_typeProperties_url')]"
					},
					"iplvault_properties_typeProperties_baseUrl": {
						"value": "[parameters('iplvault_properties_typeProperties_baseUrl')]"
					},
					"ipldatabricks_properties_typeProperties_existingClusterId": {
						"value": "[parameters('ipldatabricks_properties_typeProperties_existingClusterId')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}